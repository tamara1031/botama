DISCORD_TOKEN=your_discord_bot_token
MODULES_ENABLED=ping,notify
# GUILD_ID=your_server_id        # 設定するとギルドコマンド（即時反映）になる。未設定はグローバル（最大1時間）

# notify モジュール
API_TOKEN=your_random_secret               # openssl rand -hex 32 で生成
# NOTIFY_INFO_CHANNEL_ID=your_channel_id     # POST /notify/info の送信先（省略時 404）
# NOTIFY_WARNING_CHANNEL_ID=your_channel_id  # POST /notify/warning の送信先（省略時 404）
# NOTIFY_CRITICAL_CHANNEL_ID=your_channel_id # POST /notify/critical の送信先（省略時 404）
# API_ADDR=:8080                             # デフォルト :8080
